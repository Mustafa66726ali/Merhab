# =============================================================================
# مرحّاب — إعدادات الإنتاج (Docker Compose)
# انسخ هذا الملف إلى .env وعدّل القيم قبل التشغيل:
#   cp .env.example .env
# =============================================================================

# --- عام ---
DEBUG=False
SECRET_KEY=change-me-to-a-long-random-secret-key

# عنوان الموقع العام (الدومين) — يُستخدم في روابط الدعوة والبث
FRONTEND_URL=https://merhaab.com
ALLOWED_HOSTS=merhaab.com,www.merhaab.com
CORS_ALLOWED_ORIGINS=https://merhaab.com,https://www.merhaab.com
CSRF_TRUSTED_ORIGINS=https://merhaab.com,https://www.merhaab.com

# --- قاعدة البيانات ---
# السيرفر / Docker: اضبط PostgreSQL (مطلوب)
DB_NAME=merhab
DB_USER=merhab
DB_PASSWORD=change-me-strong-db-password
DB_HOST=db
DB_PORT=5432
# التطوير المحلي بدون Docker: احذف/علّق DB_NAME لاستخدام SQLite تلقائياً

# --- Redis (كاش + Celery) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# --- حساب مدير النظام (يُنشأ/يُحدَّث عند الإقلاع) ---
ADMIN_EMAIL=admin@merhaab.com
ADMIN_PASSWORD=Merhab@2024
ADMIN_USERNAME=admin

# --- واتساب (الإنتاج: api مع Twilio/Cloud من لوحة التكاملات) ---
WHATSAPP_PROVIDER=api
# WHATSAPP_BOT_URL=http://whatsapp-bot:8088
# WHATSAPP_BOT_TOKEN=merhab-bot-dev

# قوالب Meta المعتمدة (يُضبط لاحقاً من لوحة التكاملات أو هنا)
WHATSAPP_TEMPLATE_INVITATION=event_invitation
WHATSAPP_TEMPLATE_REMINDER=event_reminder
WHATSAPP_TEMPLATE_QR=rsvp_qr
WHATSAPP_TEMPLATE_LANGUAGE=ar

# دعوة تفاعلية (خريطة + رابط + نعم/لا) — افتراضياً مفعّلة
WHATSAPP_INVITATION_INTERACTIVE=True
# WHATSAPP_INVITATION_LEGACY_TEMPLATE=False
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=merhab-verify

# --- التذكير التلقائي ---
REMINDER_INTERVAL_SEC=300

# --- منفذ nginx الخارجي (على السيرفر) ---
HTTP_PORT=80
